{
  "log": {
    "loglevel": "none"
  },
  "inbounds": [
    {
      "listen": "0.0.0.0",
      "port": 8080,
      "protocol": "vless",
      "settings": {
        "clients": [
          {
            "id": "aeeb5f92-87c1-4fb2-b653-2367c97e0830",
            "flow": ""
          }
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "ws",
        "security": "none",
        "wsSettings": {
          "path": "/yasssss-vless-30",
          "maxEarlyData": 4096,
          "earlyDataHeaderName": "Sec-WebSocket-Protocol"
        }
      },
      "sniffing": {
        "enabled": false
      }
    }
  ],
  "outbounds": [
    {
      "protocol": "freedom",
      "tag": "direct",
      "settings": {
        "domainStrategy": "UseIP"
      }
    }
  ],
  "routing": {
    "domainStrategy": "IPIfNonMatch",
    "rules": []
  },
  "transport": {
    "tcpSettings": {
      "header": {
        "type": "none"
      }
    },
    "kcpSettings": {
      "mtu": 1350,
      "tti": 20,
      "uplinkCapacity": 100,
      "downlinkCapacity": 100,
      "congestion": false,
      "readBufferSize": 4,
      "writeBufferSize": 4
    }
  },
  "policy": {
    "levels": {
      "0": {
        "handshake": 2,
        "connIdle": 150,
        "uplinkOnly": 2,
        "downlinkOnly": 5,
        "bufferSize": 4
      }
    }
  }
}
